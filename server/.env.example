# Server configuration
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/inventory

# Wall-clock timezone for attendance check-in/out and HR calendar days.
# Use Asia/Kolkata on cloud hosts (which are usually UTC) so times match local clocks.
APP_TIMEZONE=Asia/Kolkata

# Google Gemini API key (get one from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Government e-filing gateway (GST, TDS, ITR, etc.)
GOVT_FILING_API_KEY=your_government_filing_api_key
GOVT_FILING_API_BASE_URL=https://api.example.gov.in/efiling/v1
# Exchange rates (multi-currency reporting)
# Refresh interval in minutes (default 60)
EXCHANGE_RATE_REFRESH_MINUTES=60
# Optional override. Use {base} placeholder. Default: https://open.er-api.com/v6/latest/INR
# EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/{base}
