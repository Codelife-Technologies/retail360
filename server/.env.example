# Server configuration
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/inventory

# Wall-clock timezone for attendance check-in/out and HR calendar days.
# Use Asia/Kolkata on cloud hosts (which are usually UTC) so times match local clocks.
APP_TIMEZONE=Asia/Kolkata

# Google Gemini API key (get one from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
