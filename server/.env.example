# Server Configuration
PORT=5000

# MongoDB Connection
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/inventory

# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/inventory?retryWrites=true&w=majority

# For MongoDB with authentication (local):
# MONGODB_URI=mongodb://username:password@localhost:27017/inventory?authSource=admin

# Example MongoDB Atlas connection string format:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# AI Image Generation APIs
# Google Gemini API Key (for Gemini image generation)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (for DALL-E image generation)
OPENAI_API_KEY=your_openai_api_key_here

# Note: Replace API keys with your actual values
# Get Gemini API key from: https://makersuite.google.com/app/apikey
# Get OpenAI API key from: https://platform.openai.com/api-keys
# Never commit the actual .env file to version control!
